    "build": "tsc --noEmit",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241224.0",
    "typescript": "~5.5.0",
    "wrangler": "^3.95.0"
  }
}
